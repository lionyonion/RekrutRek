# =============================================
# REKRUTREK — Backend Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL — gunakan connection string Supabase
DATABASE_URL=postgresql://user:password@host:5432/rekrutrek_db

# JWT
JWT_SECRET=ganti_dengan_string_panjang_dan_acak_minimal_32_karakter
JWT_EXPIRES_IN=7d

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# AI Service (FastAPI dari tim AI Engineer)
AI_SERVICE_URL=http://localhost:8000

# Storage untuk file CV (gunakan Supabase Storage atau lokal saat dev)
STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=5

# API Keys (opsional, jika Express perlu akses langsung)
GEMINI_API_KEY=isi_jika_diperlukan
OPENAI_API_KEY=isi_jika_diperlukan
