# =============================================
# REKRUTREK — Frontend Environment Variables
# =============================================

# URL backend Express (gunakan /api proxy saat dev via vite.config.js)
VITE_API_URL=http://localhost:5000/api

# Set ke 'true' untuk menggunakan mock data (tanpa backend)
VITE_USE_MOCK=false

# Nama aplikasi (tampil di tab browser & metadata)
VITE_APP_NAME=Rekrutrek
